# Local environment — copy to .env and adjust as needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticket_brief

# API server port (frontend proxies /api to this)
PORT=3001

# Optional: GitHub token for private repos and higher rate limits
# GITHUB_TOKEN=

# Optional: AI-generated briefings (without this, raw PR data is used)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Optional: Jira integration (currently stubbed in the API)
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_BASE_URL=https://your-org.atlassian.net
