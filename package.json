{
  "name": "ticket-brief",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "python -m uvicorn main:app --app-dir artifacts/api-server-py --port 3001 --reload",
    "dev:web": "pnpm --filter @workspace/ticket-brief run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:push": "dotenv -e .env -- pnpm --filter @workspace/db run push"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
